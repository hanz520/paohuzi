/* pages/result/result.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-bottom: 200rpx;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.trophy-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.duration {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 获胜者展示 */
.winner-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.winner-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.winner-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.4);
}

.winner-avatar text {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.winner-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.winner-score {
  font-size: 72rpx;
  font-weight: bold;
  color: #667eea;
  font-family: 'Courier New', monospace;
}

.winner-badge {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  color: #ffffff;
  padding: 12rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
}

/* 分数详情区域 */
.score-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  gap: 20rpx;
}

.score-rank {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  flex-shrink: 0;
}

.score-item:first-child .score-rank {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
}

.score-player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-player-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.score-details {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.score-final {
  font-size: 40rpx;
  font-weight: bold;
  font-family: 'Courier New', monospace;
}

.score-final.positive {
  color: #52c41a;
}

.score-final.negative {
  color: #f5222d;
}

/* 结算公式区域 */
.formula-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.formula-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.formula-arrow {
  font-size: 32rpx;
  color: #999;
}

.formula-content {
  padding-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.formula-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.formula-label {
  font-weight: 600;
  color: #333;
}

.formula-item.zero-sum {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  font-weight: 600;
  color: #667eea;
}

/* 数据保存提示 */
.save-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.save-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

/* 按钮组 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 40rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.continue-btn {
  width: 100%;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.home-btn {
  width: 100%;
  padding: 28rpx 0;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}
