<!--pages/result/result.wxml-->
<wxs module="utils">
  function formatTime(seconds) {
    if (!seconds || seconds < 0) return '0 分 00 秒';
    var hours = Math.floor(seconds / 3600);
    var mins = Math.floor((seconds % 3600) / 60);
    var secs = seconds % 60;
    
    if (hours > 0) {
      return hours + '小时' + mins + '分' + secs + '秒';
    } else {
      return mins + '分' + (secs < 10 ? '0' : '') + secs + '秒';
    }
  }
  
  function formatScore(score) {
    if (score === 0) {
      return '-';
    } else if (score > 0) {
      return '+' + score;
    } else {
      return score.toString();
    }
  }
  
  module.exports = {
    formatTime: formatTime,
    formatScore: formatScore
  };
</wxs>

<view class="container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="mode-badge">{{mode}}模式</view>
    <view class="title">游戏详情</view>
    <view class="duration">游戏时长：{{utils.formatTime(duration)}}</view>
  </view>

  <!-- 获胜者展示 -->
  <view class="winner-section">
    <view class="winner-card"> 
      <view class="winner-name">{{winner}}</view>
      <view class="winner-score">{{getWinnerScore()}}</view>
      <view class="winner-badge">获胜</view>
    </view>
    <view class="delete-btn-wrapper" wx:if="{{gameId}}">
      <view class="delete-btn-small" bindtap="onDeleteGame">
        🗑
      </view>
    </view>
  </view>

  <!-- 游戏过程表格 -->
  <view class="process-section" wx:if="{{hasConvertedScores && scoreRows.length > 0}}">
    <view class="section-title">📊 游戏过程</view>
    
    <view class="score-table-container">
      <!-- 表头（玩家名字） -->
      <view class="table-header">
        <view class="header-row">
          <view class="header-cell" wx:for="{{players}}" wx:key="name">
            <text class="player-name-text">{{item.name}}</text>
          </view>
        </view>
      </view>
      
      <!-- 表格内容（得分记录） -->
      <scroll-view class="table-body" scroll-y>
        <view class="score-row" wx:for="{{scoreRows}}" wx:key="id" id="row-{{item.id}}">
          <view class="score-cell" wx:for="{{item.scores}}" wx:key="playerIdx" wx:for-item="score" wx:for-index="playerIdx">
            <text class="score-value {{score > 0 ? 'positive' : (score < 0 ? 'negative' : '')}}">{{utils.formatScore(score)}}</text>
          </view>
        </view>
      </scroll-view>
      
      <!-- 表尾（原始总分） -->
      <view class="table-footer">
        <view class="footer-row">
          <view class="footer-cell" wx:for="{{players}}" wx:key="name">
            <text class="total-score {{item.rawScore >= 0 ? 'positive' : 'negative'}}">{{utils.formatScore(item.rawScore)}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 分数详情列表 -->
  <view class="score-section">
    <view class="section-title">📈 最终得分</view>
    
    <view class="score-list">
      <view class="score-item" wx:for="{{players}}" wx:key="name">
        <view class="score-rank">{{item.rank}}</view>
        <view class="score-player-info">
          <view class="score-player-name">{{item.name}}</view>
          <view class="score-details" wx:if="{{hasConvertedScores}}">
            <text>原始分：{{item.rawScore}}</text>
            <text>转换分：{{item.convertedScore}}</text>
          </view>
        </view>
        <view class="score-final {{item.finalScore > 0 ? 'positive' : (item.finalScore < 0 ? 'negative' : '')}}">
          {{utils.formatScore(item.finalScore)}}
        </view>
      </view>
    </view>
  </view>

  <!-- 结算公式 -->
  <view class="formula-section" bindtap="toggleFormula">
    <view class="formula-title">
      <text>📝 结算公式</text>
      <text class="formula-arrow">{{showFormula ? '↑' : '↓'}}</text>
    </view>
    
    <view class="formula-content" wx:if="{{showFormula}}">
      <view class="formula-item">
        <text class="formula-label">三人模式：</text>
        <text>最终得分 = 转换分×2 - 其他玩家转换分之和</text>
      </view>
      <view class="formula-item">
        <text class="formula-label">四人模式：</text>
        <text>最终得分 = 转换分×3 - 其他玩家转换分之和</text>
      </view>
      <view class="formula-item">
        <text class="formula-label">转换分数：</text>
        <text>原始分÷10，向上取整</text>
      </view>
      <view class="formula-item zero-sum">
        <text>零和验证：{{isZeroSum ? '✓' : '✗'}} 所有玩家最终得分之和 = {{totalScore}}</text>
      </view>
    </view>
  </view>

  <!-- 数据保存提示 -->
  <view class="save-hint" wx:if="{{saved}}">
    <text class="save-icon">✓</text>
    <text>本局数据已保存到云端</text>
  </view>

  <!-- 按钮组 -->
  <view class="action-section">
    <view class="button-row">
      <button class="continue-btn" bindtap="onContinueGame">
        继续游戏
      </button>
      <button class="home-btn" bindtap="onGoHome">
        返回首页
      </button>
    </view>
  </view>
</view>
