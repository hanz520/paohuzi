/* pages/players/detail/detail.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 玩家信息卡片 */
.player-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.player-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 40rpx;
}

.player-stats {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.stat-card {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-value.win {
  color: #ffd700;
}

.stat-value.positive {
  color: #52c41a;
}

.stat-value.negative {
  color: #ff6b6b;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 游戏记录区域 */
.games-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 游戏列表 */
.game-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.game-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.game-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-mode {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.game-time {
  font-size: 22rpx;
  color: #999;
}

/* 表格布局 */
.game-table {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.table-row {
  display: flex;
  gap: 8rpx;
}

.table-cell {
  flex: 1;
  text-align: center;
  padding: 12rpx 4rpx;
  font-size: 26rpx;
}

.player-names .table-cell {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  padding: 10rpx 4rpx;
}

.player-scores .table-cell {
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
  padding: 12rpx 4rpx;
}

.player-scores .positive {
  color: #52c41a;
}

.player-scores .negative {
  color: #f5222d;
}

.game-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.game-winner {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.game-duration {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 加载中 */
.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
}

.load-more:active {
  opacity: 0.7;
}
