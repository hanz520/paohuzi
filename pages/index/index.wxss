/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

/* 头部区域 */
.header {
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

/* 模式选择区域 */
.mode-section {
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  flex: 1;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.mode-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.mode-card {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.mode-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.mode-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.mode-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.mode-desc {
  font-size: 26rpx;
  color: #666;
}

/* 最近游戏区域 */
.recent-section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 40rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.more-link {
  font-size: 26rpx;
  color: #667eea;
  text-decoration: none;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  transition: all 0.2s ease;
}

.recent-item:active {
  background-color: #f0f0f0;
}

.recent-mode {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  white-space: nowrap;
}

.recent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recent-winner {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.recent-time {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-recent {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}
