/* pages/history/history.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 筛选区域 */
.filter-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-group {
  display: flex;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.filter-tag-small {
  padding: 8rpx 24rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.filter-tag-small.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

/* 游戏列表 */
.game-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.game-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.game-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-mode {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.game-time {
  font-size: 22rpx;
  color: #999;
}

/* 表格布局 */
.game-table {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.table-row {
  display: flex;
  gap: 8rpx;
}

.table-cell {
  flex: 1;
  text-align: center;
  padding: 12rpx 4rpx;
  font-size: 26rpx;
}

.player-names .table-cell {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  padding: 10rpx 4rpx;
}

.player-scores .table-cell {
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
  padding: 12rpx 4rpx;
}

.player-scores .positive {
  color: #52c41a;
}

.player-scores .negative {
  color: #f5222d;
}

.game-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.game-winner {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.game-duration {
  font-size: 22rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
}

.load-more:active {
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 40rpx;
}

.start-game-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 28rpx 80rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* 加载中 */
.loading-state {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}
