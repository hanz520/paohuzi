<!--pages/team-select/team-select.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <view class="title">选择队友</view>
    <view class="subtitle">请选择 2 名玩家作为你的队友</view>
  </view>

  <!-- 玩家列表 -->
  <view class="player-section">
    <view class="section-tip">已选择 {{selectedCount}} / 2 名队友</view>
    
    <view class="player-list">
      <view 
        class="player-card {{isSelected(index) ? 'selected' : ''}}" 
        wx:for="{{players}}" 
        wx:key="index"
        bindtap="onPlayerTap"
        data-index="{{index}}"
      >
        <!-- 选择标识 -->
        <view class="select-icon" wx:if="{{isSelected(index)}}">
          <text>✓</text>
        </view>
        
        <!-- 玩家头像占位 -->
        <view class="player-avatar">
          <text class="avatar-text">{{getPlayerInitial(item)}}</text>
        </view>
        
        <!-- 玩家名字 -->
        <view class="player-name">{{item}}</view>
        
        <!-- 队友标识 -->
        <view class="team-badge" wx:if="{{isSelected(index)}}">队友</view>
      </view>
    </view>
  </view>

  <!-- 组队说明 -->
  <view class="info-section">
    <view class="info-title">💡 组队规则</view>
    <view class="info-list">
      <view class="info-item">• 点击玩家卡片进行选中/取消</view>
      <view class="info-item">• 必须选择恰好 2 名玩家</view>
      <view class="info-item">• 选中的 2 名玩家为一队</view>
      <view class="info-item">• 剩余 2 名玩家自动成队</view>
    </view>
  </view>

  <!-- 确认按钮 -->
  <view class="action-section">
    <button 
      class="confirm-btn {{canConfirm ? 'enabled' : 'disabled'}}" 
      disabled="{{!canConfirm}}"
      bindtap="onConfirm"
    >
      确认组队，开始游戏
    </button>
  </view>
</view>
