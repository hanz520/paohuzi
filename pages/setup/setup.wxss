/* pages/setup/setup.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.mode-badge {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 玩家选择区域 */
.players-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.player-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.player-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  transition: all 0.2s ease;
}

.player-card:active {
  background-color: #f5f5f5;
}

.player-card.selected {
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
}
 

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.player-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.player-hint {
  font-size: 24rpx;
  color: #999;
}

.player-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.change {
  background-color: #667eea;
  color: #ffffff;
}

.action-btn.clear {
  background-color: #f5f5f5;
  color: #999;
}

.select-hint {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

/* 开始游戏按钮 */
.action-section {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
}

.start-btn {
  width: 100%;
  padding: 32rpx 0;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.start-btn.enabled {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.start-btn.disabled {
  background-color: #cccccc;
  color: #999999;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform: scale(0.9);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  background-color: #ffffff;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

/* Tab 内容区域 */
.tab-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 400rpx;
  max-height: 60vh;
  transition: all 0.3s ease;
}

.tab-content.show {
  display: flex;
  opacity: 1;
}

.tab-content.hide {
  display: none;
  opacity: 0;
}

/* 新建玩家 Tab 内容 */
.new-player-tab-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  gap: 32rpx;
}

.new-player-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.new-player-input-field {
  width: calc(100% - 32rpx);
  height: 88rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  margin: 0 16rpx;
}

.new-player-input-field:focus {
  border-color: #667eea;
  background-color: #ffffff;
}

.confirm-new-btn {
  width: 100%;
  padding: 28rpx 0;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.confirm-new-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
  box-shadow: none;
}

/* 搜索框 */
.search-box {
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* 玩家列表 */
.player-list {
  flex: 1;
  max-height: 600rpx;
}

.history-player-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.history-player-item:active {
  background-color: #f5f5f5;
}
 
 

.history-player-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.history-player-stats {
  font-size: 24rpx;
  color: #999;
}

.empty-list {
  text-align: center;
  padding: 80rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  width: 100%;
  background-color: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
}

/* 停止事件冒泡 */
.stopPropagation {
  /* 用于阻止点击内容区域时关闭弹窗 */
}
