/* pages/game/game.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.mode-badge {
  background-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.timer {
  background-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
}

/* 积分表格容器 */
.score-table-container {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  max-height: calc(100vh - 280rpx);
}

/* 表头 */
.table-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-row {
  display: flex;
}

.header-cell {
  flex: 1;
  padding: 24rpx 16rpx;
  text-align: center;
  border-right: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.header-cell:active {
  background-color: rgba(255, 255, 255, 0.2);
}

.header-cell:last-child {
  border-right: none;
}

.player-name-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

/* 表格内容区域 */
.table-body {
  flex: 1;
  overflow-y: scroll;
  background-color: #fafafa;
}

.score-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.score-cell {
  flex: 1;
  padding: 20rpx 16rpx;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-cell:last-child {
  border-right: none;
}

.score-value {
  font-size: 32rpx;
  font-weight: bold;
  font-family: 'Courier New', monospace;
}

.score-value.positive {
  color: #52c41a;
}

.score-value.negative {
  color: #f5222d;
}

/* 空提示 */
.empty-hint {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 表尾 */
.table-footer {
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
  position: sticky;
  bottom: 0;
  z-index: 10;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.footer-row {
  display: flex;
}

.footer-cell {
  flex: 1;
  padding: 24rpx 16rpx;
  text-align: center;
  border-right: 2rpx solid #d0dfff;
}

.footer-cell:last-child {
  border-right: none;
}

.total-score {
  font-size: 36rpx;
  font-weight: bold;
  font-family: 'Courier New', monospace;
}

.total-score.positive {
  color: #52c41a;
}

.total-score.negative {
  color: #f5222d;
}

/* 玩家卡片区域（已废弃，保留兼容性） */

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}

.player-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.player-score {
  font-size: 56rpx;
  font-weight: bold;
  color: #667eea;
  font-family: 'Courier New', monospace;
}

.team-tag {
  position: absolute;
  right: 0;
  top: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.team-tag.team2 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.action-btn.undo {
  background-color: #f5f5f5;
  color: #666;
}

.action-btn.undo[disabled] {
  background-color: #e0e0e0;
  color: #ccc;
}

.action-btn.end {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.4);
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-content.small {
  max-width: 500rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

/* 分数输入区域 */
.score-input-section {
  padding: 40rpx 32rpx;
}

.score-input {
  width: 100%;
  height: 100rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  font-family: 'Courier New', monospace;
}

.input-hint {
  text-align: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #f5576c;
}

/* 弹窗按钮组 */
.modal-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.modal-buttons button {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.confirm-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

.liuju-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

/* 确认弹窗 */
.confirm-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 40rpx 32rpx 20rpx;
}

.confirm-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 0 32rpx 40rpx;
}

.confirm-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.confirm-buttons button {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.confirm-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn-ok {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
}
