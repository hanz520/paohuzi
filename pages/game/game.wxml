<!--pages/game/game.wxml-->
<wxs module="utils">
  function formatTime(seconds) {
    if (!seconds || seconds < 0) return '00:00:00';
    var hours = Math.floor(seconds / 3600);
    var mins = Math.floor((seconds % 3600) / 60);
    var secs = seconds % 60;
    
    var hoursStr = (hours < 10 ? '0' : '') + hours;
    var minsStr = (mins < 10 ? '0' : '') + mins;
    var secsStr = (secs < 10 ? '0' : '') + secs;
    
    return hoursStr + ':' + minsStr + ':' + secsStr;
  }
  
  module.exports = {
    formatTime: formatTime
  };
</wxs>

<view class="container">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="mode-badge">{{mode}}模式</view>
    <view class="timer">{{utils.formatTime(timerSeconds)}}</view>
  </view>

  <!-- 积分表格 -->
  <view class="score-table-container">
    <!-- 表头（玩家名字） -->
    <view class="table-header">
      <view class="header-row">
        <view class="header-cell" wx:for="{{players}}" wx:key="index" bindtap="onPlayerHeaderTap" data-index="{{index}}">
          <text class="player-name-text">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <!-- 表格内容（得分记录） -->
    <scroll-view class="table-body" scroll-y scroll-into-view="{{scrollToView}}">
      <view class="score-row" wx:for="{{scoreRows}}" wx:key="id" id="row-{{item.id}}">
        <view class="score-cell" wx:for="{{item.scores}}" wx:key="playerIdx" wx:for-item="score" wx:for-index="playerIdx">
          <text class="score-value {{score > 0 ? 'positive' : (score < 0 ? 'negative' : '')}}">{{score > 0 ? '+' + score : score}}</text>
        </view>
      </view>
      <view wx:if="{{scoreRows.length === 0}}" class="empty-hint">
        <text>点击上方玩家名字开始计分</text>
      </view>
    </scroll-view>
    
    <!-- 表尾（总分） -->
    <view class="table-footer">
      <view class="footer-row">
        <view class="footer-cell" wx:for="{{players}}" wx:key="index">
          <text class="total-score {{item.rawScore >= 0 ? 'positive' : 'negative'}}">{{item.rawScore}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="action-btn undo" bindtap="onUndo" disabled="{{!canUndo}}">
      <text>撤销</text>
    </button>
    <button class="action-btn end" bindtap="onEndGame">
      <text>结束游戏</text>
    </button>
  </view>
  <view class="modal {{showScoreInput ? 'show' : ''}}" bindtap="onModalMaskTap">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">{{currentPlayerName}} - 计分</view>
        <view class="modal-close" bindtap="closeScoreInput">✕</view>
      </view>
      
      <view class="score-input-section">
        <input 
          class="score-input" 
          type="number" 
          placeholder="请输入分数（≥10）"
          value="{{inputScore}}"
          bindinput="onScoreInput"
          focus="{{showScoreInput}}"
        />
        <view class="input-hint" wx:if="{{inputScore && inputScore < 10}}">
          ⚠ 分数必须大于等于 10
        </view>
      </view>
      
      <view class="modal-buttons">
        <button class="confirm-btn" disabled="{{!canConfirmScore}}" bindtap="onConfirmScore">
          确认加分
        </button>
        <button class="liuju-btn" wx:if="{{mode === '4 人'}}" bindtap="onLiuJu">
          流局（-10 分）
        </button>
        <button class="cancel-btn" bindtap="closeScoreInput">
          取消
        </button>
      </view>
    </view>
  </view>
</view>
